# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_LOGIN_BOT_TOKEN=
RUN_MODE=polling

# Dujiao-Next
DUJIAO_BASE_URL=https://user.example.com
DUJIAO_API_PREFIX=/api/v1
SHOP_BASE_URL=https://shop.example.com
SUPPORT_URL=https://t.me/your_support
DEFAULT_LOCALE=zh-CN

# Local runtime
DB_PATH=kabot.sqlite3
LOG_LEVEL=INFO
POLL_TIMEOUT_SECONDS=30
POLL_INTERVAL_SECONDS=1

# Admin and security
# Chat IDs, comma separated. Use /admin after starting the bot to see your chat id.
ADMIN_CHAT_IDS=
KABOT_EVENT_SECRET=change-this-event-secret
WEBHOOK_SECRET_TOKEN=change-this-webhook-secret
WEBHOOK_PUBLIC_URL=https://bot.example.com/telegram/webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/telegram/webhook
EVENT_PATH=/kabot/events

# Payment channels are not exposed by the documented public API, so keep them configurable.
PAYMENT_CHANNELS=[{"id":10,"name":"Alipay"},{"id":20,"name":"WeChat"},{"id":30,"name":"USDT"},{"id":40,"name":"PayPal"},{"id":50,"name":"Stripe"}]

# Optional endpoint overrides. Keep empty unless your Dujiao-Next build exposes these paths differently.
DUJIAO_ENDPOINTS={}

# If Dujiao Telegram login uses the same bot token, the bot can create a verified Telegram login payload.
ENABLE_SYNTHETIC_TELEGRAM_LOGIN=true

# If the current Dujiao API requires a SKU field in order items, set it here, for example sku_id.
ORDER_SKU_FIELD=
